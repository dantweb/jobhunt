# jobhunt configuration — copy to .env and fill in.

# LLM provider — pick one
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_RANK=claude-haiku-4-5
ANTHROPIC_MODEL_TAILOR=claude-sonnet-4-6
ANTHROPIC_MODEL_PROFILE=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL_RANK=gpt-4o-mini
OPENAI_MODEL_TAILOR=gpt-4o
OPENAI_MODEL_PROFILE=gpt-4o

# Source credentials (optional — sources without keys are skipped)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=

# SMTP for sending applications.
#
# ── Option A (default): Mailpit container ────────────────────────────────────
# `docker compose up -d mailpit` then open http://localhost:8125 to inspect
# every email jobhunt would send — nothing leaves your machine.
# (Port 8125 is intentional — keeps jobhunt's mailpit from clashing with
# other projects on the default 8025.)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_STARTTLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=jobhunt@local.test
#
# ── Option B: SMTP daemon running on YOUR HOST (postfix, sendmail, etc.) ─────
# From inside the jobhunt container, "localhost" is the container itself,
# so a daemon listening on the host's 127.0.0.1 is reached via
# `host.docker.internal`. docker-compose.yml maps this for Linux too via
# extra_hosts → host-gateway. Replace the Option A block with:
#   SMTP_HOST=host.docker.internal
#   SMTP_PORT=25                    # or 587 / 1025, whatever your daemon uses
#   SMTP_USE_STARTTLS=false         # set to true if your daemon advertises STARTTLS
#   SMTP_USER=
#   SMTP_PASSWORD=
#   SMTP_FROM=you@local.example
#
# ── Option C: Real production SMTP (e.g. Gmail) ──────────────────────────────
# Replace the Option A block with:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_STARTTLS=true
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=<app-password>
#   SMTP_FROM=you@gmail.com

# Owner profile
CV_PATH=/app/var/cv/cv.pdf
OWNER_NAME=
OWNER_EMAIL=

# Database
DB_PATH=/app/jobhunt.sqlite

# Config
CONFIG_PATH=/app/config.toml
